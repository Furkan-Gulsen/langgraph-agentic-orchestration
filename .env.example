# OpenAI (required for live runs)
OPENAI_API_KEY=sk-...

# Default chat model (cost/performance balance)
OPENAI_MODEL=gpt-4o-mini

# Request timeouts (seconds)
OPENAI_TIMEOUT_SECONDS=120.0

# LLM retry policy
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT_SECONDS=1.0
LLM_RETRY_MAX_WAIT_SECONDS=30.0

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false
